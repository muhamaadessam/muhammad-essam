rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /stats/{document=**} {
      allow read: if true;
      allow write: if true;
    }
    
    match /messages/{document=**} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
    
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
